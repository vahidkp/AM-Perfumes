# Razorpay — leave blank to use the built-in demo checkout (no real payment).
# Public key is exposed to the browser; secret stays server-side only.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Public site URL (used for canonical/OG/sitemap)
NEXT_PUBLIC_SITE_URL=https://amperfume.example
